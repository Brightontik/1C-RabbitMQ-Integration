// ==============================================================================
// СЕРВЕРНАЯ ЛОГИКА ТЕСТОВОГО ПОЛИГОНА
// ==============================================================================

&НаСервере
Процедура ВыполнитьТестСвязиНаСервере()
	
	КлючСети       = "ОсновнойКонтур";
	ЦелеваяОчередь = "testroute";
	УникальныйИД   = Строка(Новый УникальныйИдентификатор);
	
	ТестоваяСтруктура = Новый Структура("Тест, ID, Время", "Пинг Кролика", УникальныйИД, ТекущаяДата());
	
	Попытка
		// 1. Отправляем тестовую структуру (общий модуль сам сделает нативный JSON)
		ИнтеграцияRabbitMQСервер.ОтправитьСообщение(КлючСети, ЦелеваяОчередь, ТестоваяСтруктура, Ложь);
		Сообщить(СтрШаблон("Шаг 1: Тестовый пакет [%1] отправлен в сеть.", УникальныйИД));
		
		// 2. Сразу открываем сокет обратно для экспресс-теста чтения
		Настройки = ИнтеграцияRabbitMQСервер.ПолучитьНастройкиПодключения(КлючСети);
		КлиентRMQ = ИнтеграцияRabbitMQСервер.УстановитьСоединение(Настройки);
		
		Потребитель = КлиентRMQ.BasicConsume(ЦелеваяОчередь, "", Истина, Ложь, 0);
		
		ОтветныйТекст = "";
		ТегСообщения  = 0;
		
		Если КлиентRMQ.BasicConsumeMessage(Потребитель, ОтветныйТекст, ТегСообщения, 3000) Тогда
			КлиентRMQ.BasicAck(ТегСообщения);
			Сообщить("Шаг 1: Отлично! Пакет вернулся из сети: " + ОтветныйТекст);
		Иначе
			Сообщить("Шаг 1: Ошибка! Сообщение застряло в сети брокера.");
		КонецЕсли;
		
		КлиентRMQ.BasicCancel(Потребитель);
		КлиентRMQ = Неопределено;
		
	Исключение
		Сообщить("Критический сбой Шага 1: " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьЛокальнуюЗаписьНаСервере()
	
	КлючСети       = "ОсновнойКонтур";
	ЦелеваяОчередь = "testroute";
	
	// Имитируем проведение документов пользователями. Генерируем пачку из 3-х заказов.
	Для Счетчик = 1 По 3 Цикл
		БизнесПакет = Новый Структура;
		БизнесПакет.Вставить("СтатусЗаказа", "Новый");
		БизнесПакет.Вставить("Сумма",        Счетчик * 8500);
		БизнесПакет.Вставить("Менеджер",     "Компадре");
		
		// Локальная запись в Outbox. Данные сжимаются алгоритмом ZIP в ХранилищеЗначений
		ИнтеграцияRabbitMQСервер.ЗарегистрироватьКВыгрузке(КлючСети, ЦелеваяОчередь, БизнесПакет);
	КонецЦикла;
	
	Сообщить("Шаг 2: В РС 'Очередь исходящих' успешно добавлено 3 сжатых пакета. Сеть не трогалась.");
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьВыгрузкуВRabbitMQНаСервере()
	
	Попытка
		// Запуск регламента №1: Твой крутой оконный запрос выгребает пачку и шлет в Кролика
		ИнтеграцияRabbitMQСервер.ВыполнитьВыгрузкуПакетовВRabbitMQ();
		Сообщить("Шаг 3: Оконный запрос отработал. Данные улетели в RabbitMQ. РС исходящих чист.");
	Исключение
		Сообщить("Ошибка Шага 3: " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьЗагрузкуИзRabbitMQНаСервере() 
	
	КлючСети       = "ОсновнойКонтур";
	ЦелеваяОчередь = "testroute";
	
	Попытка
		// Запуск регламента №2: Пакетный забор через НаборЗаписей одной транзакцией в РС входящих
		ИнтеграцияRabbitMQСервер.ВыполнитьЗагрузкуПакетовИзRabbitMQ();
		Сообщить("Шаг 4: Набор записей зафиксировал пакет ответов из шины в РС 'Очередь входящих'.");
	Исключение
		Сообщить("Ошибка Шага 4: " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьПарсингВходящихНаСервере()
	
	Попытка
		// Запуск регламента №3: Поднимаем BLOB, разжимаем, парсим потоковым JSON в транзакции
		ИнтеграцияRabbitMQСервер.ВыполнитьОбработкуВходящихПакетов();
		Сообщить("Шаг 5: Процессор входящих успешно десериализовал JSON и залогировал данные в БСП.");
	Исключение
		Сообщить("Ошибка Шага 5: " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура СинхронизироватьИнфраструктуруНаСервере()
	Попытка
		ИнтеграцияRabbitMQСервер.СинхронизироватьОчередиСRabbitMQ();
		Сообщить("Успешно! 1С опросила HTTP API Кролика. Проверь РС 'Очереди к загрузке'.");
	Исключение
		Сообщить("Ошибка синхронизации: " + ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры